    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.3.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "~5.8.3",
